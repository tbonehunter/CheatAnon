+using StardewValley;
+using StardewValley.Tools;
+
+namespace CJBCheatsMenu.Framework.Cheats.Warps;
+
+/// <summary>
+/// Provides progression-based restriction checks for warp locations.
+/// All restrictions are optional and controlled by the EnforceWarpProgressionRestrictions config property.
+/// </summary>
+internal static class WarpRestrictions
+{
+	/// <summary>
+	/// Check if Desert area (Sandy's Shop, Skull Cavern, Casino) is unlocked.
+	/// Requires Vault bundles complete (bus repair) OR Joja membership.
+	/// </summary>
+	public static bool IsDesertUnlocked()
+	{
+		// Community Center route: Vault bundles complete
+		bool ccRoute = Game1.MasterPlayer.mailReceived.Contains("ccVault");
+		
+		// Joja route: membership bypasses bundle restrictions
+		bool jojaRoute = Game1.MasterPlayer.mailReceived.Contains("JojaMember");
+		
+		return ccRoute || jojaRoute;
+	}
+
+	/// <summary>
+	/// Check if Quarry is unlocked.
+	/// Requires Crafts Room bundles complete OR Joja membership.
+	/// </summary>
+	public static bool IsQuarryUnlocked()
+	{
+		// Community Center route: Crafts Room bundles complete
+		bool ccRoute = Game1.MasterPlayer.mailReceived.Contains("ccCraftsRoom");
+		
+		// Joja route: membership bypasses bundle restrictions
+		bool jojaRoute = Game1.MasterPlayer.mailReceived.Contains("JojaMember");
+		
+		return ccRoute || jojaRoute;
+	}
+
+	/// <summary>
+	/// Check if Railroad/Bathhouse/Witch's Swamp area is unlocked.
+	/// Accessible starting Summer 3, Year 1 (after rubble clears night of Summer 2).
+	/// </summary>
+	public static bool IsRailroadUnlocked()
+	{
+		// Calculate current game date (days since start)
+		int currentDate = (Game1.year - 1) * 112 + Game1.dayOfMonth + Game1.season.ToLower() switch
+		{
+			"spring" => 0,
+			"summer" => 28,
+			"fall" => 56,
+			"winter" => 84,
+			_ => 0
+		};
+		
+		// Rubble clears night of Summer 2, Year 1 = day 30 of year 1
+		int unlockDate = 28 + 2; // Summer day 2 = day 30 overall
+		return currentDate >= unlockDate;
+	}
+
+	/// <summary>
+	/// Check if Mutant Bug Lair is unlocked.
+	/// Requires BOTH Rusty Key (Sewer access) AND Dark Talisman quest completion.
+	/// </summary>
+	public static bool IsMutantBugLairUnlocked()
+	{
+		bool hasSewerAccess = Game1.player.hasRustyKey;
+		bool hasCompletedQuest = Game1.player.hasMagicInk; // Received after Dark Talisman quest
+		
+		return hasSewerAccess && hasCompletedQuest;
+	}
+
+	/// <summary>
+	/// Check if Secret Woods is unlocked.
+	/// Requires Steel Axe or better to remove blocking log.
+	/// </summary>
+	public static bool IsSecretWoodsUnlocked()
+	{
+		Tool? axe = Game1.player.getToolFromName("Axe");
+		if (axe != null)
+		{
+			// 0=Basic, 1=Copper, 2=Steel, 3=Gold, 4=Iridium
+			return axe.UpgradeLevel >= 2;
+		}
+		return false;
+	}
+
+	/// <summary>
+	/// Check if Wizard Tower area is unlocked.
+	/// Accessible after Community Center is discovered.
+	/// </summary>
+	public static bool IsWizardTowerUnlocked()
+	{
+		// Check if player has triggered CC unlock or received wizard's letter
+		return Game1.MasterPlayer.mailReceived.Contains("wizardJunimoNote") || 
+		       Game1.MasterPlayer.eventsSeen.Contains(611439); // CC unlock event
+	}
+
+	/// <summary>
+	/// Check if Sewer is unlocked.
+	/// Requires Rusty Key from Gunther.
+	/// </summary>
+	public static bool IsSewerUnlocked()
+	{
+		return Game1.player.hasRustyKey;
+	}
+
+	/// <summary>
+	/// Check if Ginger Island is unlocked.
+	/// Requires boat repair completion.
+	/// </summary>
+	public static bool IsGingerIslandUnlocked()
+	{
+		return Game1.MasterPlayer.mailReceived.Contains("willyBoatFixed");
+	}
+
+	/// <summary>
+	/// Check if Mastery Cave is unlocked.
+	/// Requires reaching Mastery level in any skill.
+	/// </summary>
+	public static bool IsMasteryCaveUnlocked()
+	{
+		// Check if player has achieved any mastery level
+		return Game1.player.stats.Get("MasteryExp") > 0;
+	}
+}
