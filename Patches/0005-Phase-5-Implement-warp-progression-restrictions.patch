+	/// <summary>
+	/// Check if a warp is restricted based on progression restrictions.
+	/// </summary>
+	private bool IsWarpRestricted(WarpContentModel warp, CheatContext context)
+	{
+		// If progression restrictions are disabled, no warps are restricted
+		if (!context.Config.EnforceWarpProgressionRestrictions)
+			return false;
+		
+		// Check location-specific restrictions
+		string location = warp.Location.ToLower();
+		
+		// Ginger Island locations
+		if (location.StartsWith("island"))
+			return !WarpRestrictions.IsGingerIslandUnlocked();
+		
+		// Desert area (includes Skull Cavern, Casino, Sandy's shop)
+		if (location == "desert" || location == "skullcave")
+			return !WarpRestrictions.IsDesertUnlocked();
+		
+		// Quarry
+		if (location == "mountain" && warp.DisplayName.Contains("Quarry"))
+			return !WarpRestrictions.IsQuarryUnlocked();
+		
+		// Railroad/Bathhouse area
+		if (location == "railroad" || location == "bathhouse")
+			return !WarpRestrictions.IsRailroadUnlocked();
+		
+		// Sewer
+		if (location == "sewer")
+			return !WarpRestrictions.IsSewerUnlocked();
+		
+		// Mutant Bug Lair (inside Sewer)
+		if (location == "bugland")
+			return !WarpRestrictions.IsMutantBugLairUnlocked();
+		
+		// Secret Woods
+		if (location == "woods")
+			return !WarpRestrictions.IsSecretWoodsUnlocked();
+		
+		// Wizard Tower area
+		if (location == "wizardhouse")
+			return !WarpRestrictions.IsWizardTowerUnlocked();
+		
+		// Mastery Cave
+		if (location.Contains("mastery"))
+			return !WarpRestrictions.IsMasteryCaveUnlocked();
+		
+		// No restriction for this location
+		return false;
+	}
 
